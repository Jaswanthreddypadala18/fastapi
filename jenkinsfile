pipeline{
    agent any

      environment {
        APP_NAME = "fastapi-app"

        stages{
            stage('checkout'){
                step{
                    git 'https://github.com/Jaswanthreddypadala18/fastapi.git'

            stage('build'){
                step{
                    sh 'pip install -r requirements.txt'
                        'pip install pytest'
                        'python --version'

                echo: 'building is done' 

            stage('test'){
                step{
                    
                     sh 'pytest'

                echo 'testing done'
            
            stage('running'){
                step{
                    sh 'uvicorn main:app --host 0.0.0.0 --port 8000 '


     
        post {
            always {
                 echo "Pipeline Completed"
        }
        success {
            echo "Build Success "
        }
        failure {
            echo "Build Failed "
        }

        
                }
            }
            
                }
            }


                }
                
           
            }
                }
            }

        }



    }

    

    
}